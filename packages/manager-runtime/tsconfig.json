{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@autoaide/executor-codex": ["../executor-codex/src/index.ts"],
      "@autoaide/manager-core": ["../manager-core/src/index.ts"],
      "@autoaide/memory-system": ["../memory-system/src/index.ts"],
      "@autoaide/task-system": ["../task-system/src/index.ts"]
    }
  },
  "references": [
    { "path": "../executor-codex" },
    { "path": "../manager-core" },
    { "path": "../memory-system" },
    { "path": "../task-system" }
  ],
  "include": ["src/**/*.ts"]
}
